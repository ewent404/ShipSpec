{
  "name": "shipspec",
  "version": "0.3.0",
  "description": "Spec-to-ship workflow for AI-assisted software delivery.",
  "type": "module",
  "private": false,
  "license": "MIT",
  "keywords": [
    "ai",
    "agents",
    "openspec",
    "workflow",
    "cli",
    "delivery"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ewent404/ShipSpec.git"
  },
  "bin": {
    "gsd": "bin/gsd.mjs"
  },
  "files": [
    "bin",
    "src",
    "skills",
    "examples",
    "apps/desktop/main.js",
    "apps/desktop/package.json",
    "apps/desktop/preload.js",
    "apps/desktop/renderer",
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "cli": "node bin/gsd.mjs",
    "build": "tsc --noEmit",
    "install:local": "npm link",
    "lint": "node --check src/gsd.mjs && node --check bin/gsd.mjs && node --check test/gsd.test.mjs",
    "test": "node --test",
    "test:e2e": "node --test",
    "typecheck": "tsc --noEmit && node --check src/gsd.mjs && node --check bin/gsd.mjs && node --check test/gsd.test.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20"
  }
}
